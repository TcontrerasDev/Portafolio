<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Bloquear acceso a archivos sensibles y logs si existieran
<FilesMatch "^(\.env|error_log|\..*)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si lo que piden NO es una carpeta real (-d)
    RewriteCond %{REQUEST_FILENAME} !-d
    # Y NO es un archivo real (como una imagen o un CSS) (-f)
    RewriteCond %{REQUEST_FILENAME} !-f
    
    # Entonces, envía la petición obligatoriamente a index.php
    RewriteRule ^(.*)$ index.php [L]
</IfModule>