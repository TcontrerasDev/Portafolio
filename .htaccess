<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 1. Seguridad: Bloquear acceso a archivos que empiezan con punto (.env, .htaccess, .git, etc)
    RewriteRule (^|/)\.(?!well-known\/) - [F]

    # 2. Seguridad: Bloquear archivos de configuración sensibles y logs
    <FilesMatch "\.(env|log|ini|json|md|sql)$">
        <IfModule mod_authz_core.c>
            Require all denied
        </IfModule>
        <IfModule !mod_authz_core.c>
            Order deny,allow
            Deny from all
        </IfModule>
    </FilesMatch>

    # 3. Si se pide la raíz exacta, enviarla a public/
    RewriteRule ^$ public/ [L]

    # 4. Si es un directorio que existe (subsitio) y no es la raíz, dejarlo pasar
    # El .+ asegura que estemos pidiendo "algo" dentro de la carpeta
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^.+ - [L]

    # 5. Todo lo demás (rutas del sitio) enviarlo a public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
