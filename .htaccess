<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 1. Seguridad: Bloquear acceso a archivos que empiezan con punto (.env, .htaccess, .git, etc)
    RewriteRule (^|/)\.(?!well-known\/) - [F]

    # 2. Seguridad: Bloquear archivos de configuración sensibles y logs
    <FilesMatch "\.(env|log|ini|json|md|sql)$">
        <IfModule mod_authz_core.c>
            Require all denied
        </IfModule>
        <IfModule !mod_authz_core.c>
            Order deny,allow
            Deny from all
        </IfModule>
    </FilesMatch>

    # 3. Redirige todo el tráfico que llega aquí hacia la carpeta public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
